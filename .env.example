# Repo de tesis a gestionar
REPO_URL=https://github.com/NicoMiretti/Tesis.git
REPO_BRANCH=main

# Personal Access Token con permisos repo (https://github.com/settings/tokens)
# NUNCA pongas el PAT real acá. Copiá este archivo a .env.local (gitignored) y editá ahí.
GITHUB_PAT=ghp_xxx

# Identidad para commits
GIT_AUTHOR_NAME=Tu Nombre
GIT_AUTHOR_EMAIL=tu-email@dominio.com

# Carpetas relativas al repo clonado
SOURCE_DIR=tesis/capitulos
FINAL_DIR=tesis/final
AUX_DIR=tesis/auxiliares
NOTES_DIR=tesis/notas
BIBTEX_FILE=fuentes/referencias.bib
